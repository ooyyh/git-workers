{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "git-workers",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-04",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },

  "//limits": "Paid plan: raise the per-request CPU budget so larger pushes/fetches don't hit 'Worker exceeded CPU time limit'. Default ~30s; this sets 60s. Free plan is capped at 10ms and will reject most real pushes.",
  "limits": { "cpu_ms": 60000 },

  "//vars": "Non-secret config here. Secrets (STORAGE_*, AUTH_TOKEN, ADMIN_PASSWORD, CONFIG_KEY) go in .dev.vars (local) or `wrangler secret put` (deployed) — NEVER commit them.",
  "vars": {
    "STORAGE_TYPE": "memory",
    "STORAGE_PREFIX": "",
    "AUTH_TOKEN": "",
    "ADMIN_PASSWORD": ""
  },

  "//d1": "Optional. Add a D1 binding to enable the admin panel + multi-backend mode. Create with: wrangler d1 create git-workers, then fill in database_id.",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "git-workers",
      "database_id": "REPLACE_WITH_d1_create_output",
      "migrations_dir": "./migrations"
    }
  ]
}

