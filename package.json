{
  "name": "git-workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Git smart-HTTP server running on Cloudflare Workers with pluggable S3-compatible / WebDAV object storage backends.",
  "license": "ISC",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typegen": "wrangler types",
    "typecheck": "wrangler types && tsc --noEmit",
    "test:protocol": "node test/_bundle-worker.mjs && node --experimental-strip-types test/protocol.ts",
    "test:roundtrip": "node test/_bundle-pack.mjs && node --experimental-strip-types test/roundtrip.ts",
    "test:admin": "node test/_bundle-worker.mjs && node --experimental-strip-types test/admin.ts",
    "test:e2e": "node --experimental-strip-types test/e2e.ts",
    "test": "npm run test:protocol && npm run test:roundtrip && npm run test:admin"
  },
  "dependencies": {
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250615.0",
    "@types/pako": "^2.0.3",
    "typescript": "^5.7.0",
    "wrangler": "^4.20.0"
  }
}
